# Copy to ".env.local" in this project folder (not committed). No spaces around "=".
# Restart "npm run dev" after saving. URL must be https://YOUR_REF.supabase.co (no /rest/v1/).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_or_publishable_key
# VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_or_publishable_key

# If you use "npm run preview" or static hosting without build-time env, also copy
# public/supabase-config.example.json → public/supabase-config.json and fill it in
# (that file is gitignored when it contains real keys).
